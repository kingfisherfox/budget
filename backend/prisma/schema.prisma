generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("USER") // "ADMIN" or "USER"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]
  categories   Category[]
  appSettings  AppSettings?
}

model SystemSettings {
  id             String  @id @default("1")
  signupsEnabled Boolean @default(true)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AppSettings {
  userId       String @id
  currencyCode String @default("THB")
  domainName   String @default("")
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id         String   @id @default(cuid())
  name       String
  color      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget     CategoryBudget?
  expenses   Expense[]
  recurring  RecurringExpense[]
  wishlist   WishlistItem[]
}

model CategoryBudget {
  id            String   @id @default(cuid())
  categoryId    String   @unique
  monthlyAmount Decimal  @db.Decimal(14, 2)
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Expense {
  id                       String   @id @default(cuid())
  name                     String   @default("")
  categoryId               String
  amount                   Decimal  @db.Decimal(14, 2)
  date                     DateTime @db.Date
  note                     String?
  recurringExpenseId       String?
  recurringSubcategoryId   String?
  createdAt                DateTime @default(now())
  category                 Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  recurringExpense         RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  recurringSubcategory     RecurringSubcategory? @relation(fields: [recurringSubcategoryId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([categoryId, date])
}

model RecurringExpense {
  id             String                  @id @default(cuid())
  name           String
  categoryId     String
  defaultAmount  Decimal?                @db.Decimal(14, 2)
  isCommon       Boolean                 @default(false)
  sortOrder      Int                     @default(0)
  createdAt      DateTime                @default(now())
  category       Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  expenses       Expense[]
  subcategories  RecurringSubcategory[]
}

model RecurringSubcategory {
  id                 String   @id @default(cuid())
  recurringExpenseId String
  name               String
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  recurringExpense   RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  expenses           Expense[]

  @@index([recurringExpenseId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  amount     Decimal  @db.Decimal(14, 2)
  note       String?
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
}
