# Copy this file to `.env` in the project root and adjust values.
# Docker Compose loads `.env` for `${VAR}` substitution in docker-compose.yml`.
#
# Auth: there is no signup. The API creates/updates ONE user from BUDGET_ADMIN_* on every startup.
# See README.md (Authentication) and docs/deployment.md.

# PostgreSQL (local dev / override Compose defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expenses

# Single app user — created or updated when the API starts (no signup).
# Username: 3–64 characters, letters, numbers, underscore, hyphen only.
BUDGET_ADMIN_USERNAME=owner
# Password: 8–128 characters. Change this before exposing the app.
BUDGET_ADMIN_PASSWORD=change_me_now_8chars_min

# API port (optional; default 4000)
# PORT=4000
